{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/gwongwangjae/home-search/.codex/hooks/pre_tool_use_policy.py",
            "timeoutSec": 5,
            "async": false,
            "statusMessage": "Home Search 사전 도구 정책"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/gwongwangjae/home-search/.codex/hooks/post_tool_use_review.py",
            "timeoutSec": 5,
            "async": false,
            "statusMessage": "Home Search 도구 실행 후 검토"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/gwongwangjae/home-search/.codex/hooks/stop_verification_gate.py",
            "timeoutSec": 10,
            "async": false,
            "statusMessage": "Home Search 검증 게이트"
          }
        ]
      }
    ]
  }
}
