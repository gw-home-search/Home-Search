# Home Search API local runtime example. Do not put real secrets in this file.

SPRING_PROFILES_ACTIVE=local
DB_JDBC_URL=jdbc:postgresql://localhost:15432/home_search
DB_USERNAME=home_search
DB_PASSWORD=home_search_local_password
SPRING_FLYWAY_LOCATIONS=classpath:db/migration/api,classpath:db/seed/local
FRONTEND_URL=http://localhost:5173
SERVER_PORT=8080

# RTMS live ingest is off by default. Set Open API service keys only in your local shell.
# Decoding keys are easiest to inspect, but portal Encoding keys are accepted too.
APT_SERVICE_KEY=
VW_SERVICE_KEY=
HOME_INGEST_RTMS_ENABLED=false
HOME_INGEST_RTMS_LAWD_CD=11680
HOME_INGEST_RTMS_DEAL_YMD=202512
HOME_INGEST_RTMS_PAGE_NO=1

# VWorld continuous cadastral SHP coordinate snapshot import.
# Run API/Flyway migrations before running the coordinate-import compose profile.
HOME_COORDINATE_HOST_SHP_DIR=../coordinate-input
HOME_COORDINATE_SNAPSHOT_VERSION=
HOME_COORDINATE_INPUT_FORMAT=auto
HOME_COORDINATE_EXPECTED_REGIONS=
HOME_COORDINATE_SOURCE_SRID=5186
HOME_COORDINATE_TARGET_SRID=4326
HOME_COORDINATE_REQUIRE_FULL_REGIONS=true
HOME_COORDINATE_ALLOW_MIXED_VERSION=false
HOME_COORDINATE_STRICT_REGION_MATCH=true
HOME_COORDINATE_VALIDATE_PRJ=true
HOME_COORDINATE_SYNC_PARCEL=true
